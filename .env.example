# ===== DJANGO SOZLAMALARI =====
SECRET_KEY=replace-with-strong-secret-key-change-in-production
DEBUG=False
ENVIRONMENT=development
USE_HTTPS=true

# ===== DOMAIN SOZLAMALARI =====
# Local: 127.0.0.1,localhost
# Production: your-app.up.railway.app,anistream.uz
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost

# ===== DATABASE (Development: SQLite, Production: PostgreSQL) =====
# Development uchun: ENVIRONMENT=development (SQLite)
# Production uchun: ENVIRONMENT=production (PostgreSQL)
DB_NAME=bestmedia_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== CLOUDINARY (Optional - Media fayllar uchun) =====
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== LOGGING =====
DJANGO_LOG_LEVEL=INFO


